# =============================================================================
# Windsurf Tool - Environment Configuration
# =============================================================================
# Copy this file to .env and edit values as needed.
# Environment variables override config/default.json and built-in defaults.
# Priority: env vars > config file > built-in defaults
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18371
GATEWAY_TLS_ENABLE=false
GATEWAY_TLS_CERT=
GATEWAY_TLS_KEY=

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
GATEWAY_MAX_RETRIES=3
GATEWAY_MAX_RETRY_INTERVAL=30
GATEWAY_ROUTING_STRATEGY=health-first
GATEWAY_PROXY_URL=
GATEWAY_PASSTHROUGH_HEADERS=false
GATEWAY_NON_STREAM_KEEPALIVE=0
GATEWAY_STREAMING_KEEPALIVE=15
GATEWAY_STREAMING_BOOTSTRAP_RETRIES=1
GATEWAY_WS_AUTH=false

# -----------------------------------------------------------------------------
# Pool
# -----------------------------------------------------------------------------
POOL_HEALTH_CHECK_INTERVAL=300000
POOL_BUFFER_SIZE=10
POOL_AUTO_RECOVERY=true

# -----------------------------------------------------------------------------
# Quota
# -----------------------------------------------------------------------------
QUOTA_AUTO_SWITCH=true
QUOTA_WARNING_THRESHOLD=0.8
QUOTA_SWITCH_PREVIEW_MODEL=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECURITY_CLOAKING_ENABLED=false
SECURITY_RATE_LIMIT=60
SECURITY_AUDIT_LOG=true

# -----------------------------------------------------------------------------
# Statistics
# -----------------------------------------------------------------------------
STATISTICS_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOGGING_TO_FILE=false
LOGGING_LEVEL=info

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
WORKER_SECRET_KEY=your_worker_secret_key_here
FIREBASE_API_KEY=your_firebase_api_key_here
